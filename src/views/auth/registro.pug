extends ../layout/index
block contenido 
    .py-10
         h1.text-4xl.my-10.font-extrabold.text-center Canton
            span.font-normal Finder
         h2.text-center.text-2xl.font-extrabold Registrarse

         .mt-8.mx-auto.max-w-md.shadow
            .bg-white.py-8.px-4.shadow
                form.space-y-3(method="POST" action="/auth/registro")
                    div 
                        label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="nombre") Nombre
                        input#nombre.w-full.px-3.py-2.border.border-gray-300.rounded-md.placeholder-gray-200(placeholder="Ej. Jaristhon Siles" type="text" name="nombre")
                    div 
                        label.block.text-sm.uppercase.text-gray-500.mb-1.font-bold.py-2(for="email") Email
                        input#email.w-full.px-3.py-2.border.border-gray-300.rounded-md.placeholder-gray-200(placeholder="Ej. micorreo@gmail.com" type="email" name="email")    
                    div 
                        label.block.text-sm.uppercase.text-gray-500.mb-1.font-bold.py-2(for="password") Contraseña
                        input#password.w-full.px-3.py-2.border.border-gray-300.rounded-md.placeholder-gray-200(placeholder="Ingresa tu contraseña" type="password" name="password") 
                    div 
                        label.block.text-sm.uppercase.text-gray-500.mb-1.font-bold.py-2(for="repetir_password") Confirma tu contraseña
                        input#repetir_password.w-full.px-3.py-2.border.border-gray-300.rounded-md.placeholder-gray-200(placeholder="Ingresa nuevamente tu contraseña" type="password" name="repetir_password") 

                    div.flex.items-center.justify-between    
                        a.text-gray-300.text-xs(href="/auth/login") ¿Ya tienes una cuenta? Inicia sesión 
            

                    input(class="w-full bg-indigo-600 hover:bg-indigo-800 text-white font-bold py-3" type="submit" value="Confirmar Registro")   
            