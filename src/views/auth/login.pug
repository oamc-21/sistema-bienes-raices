extends ../layout/index
block contenido 
    div
         h2.text-center.text-2xl.font-extrabold Iniciar sesión

         .mt-8.mx-auto.max-w-md.shadow
            .bg-white.py-8.px-4.shadow
                form.space-y-3
                    div 
                        label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="email") Ingresa tu correo
                        input#email.w-full.px-3.py-2.border.border-gray-300.rounded-md.placeholder-gray-200(placeholder="Ej. tucorreo@gmail.com" type="email" name="email")            
                    div 
                        label.block.text-sm.uppercase.text-gray-500.mb-1.font-bold.py-2(for="password") Contraseña
                        input#password.w-full.px-3.py-2.border.border-gray-300.rounded-md.placeholder-gray-200(placeholder="Ingresa tu contraseña" type="password" name="password") 
                    
                    div.flex.items-center.justify-between    
                        a.text-gray-300.text-xs(href="/auth/registro") ¿No tienes una cuenta? Registrate
                        a.text-gray-300.text-xs(href="/auth/recuperar-cuenta") ¿Olvidaste tu contraseña? 

                    input(class="w-full bg-indigo-600 hover:bg-indigo-800 text-white font-bold py-3" type="submit" value="Iniciar sesión")  